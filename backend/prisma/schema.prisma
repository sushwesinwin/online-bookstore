generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String           @id @default(cuid())
  email               String           @unique
  password            String
  firstName           String
  lastName            String
  profileImage        String?
  role                Role             @default(USER)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  cart                CartItem[]
  favorites           Favorite[]
  orders              Order[]
  blogPosts           BlogPost[]
  following           UserFollow[]     @relation("FollowFollower")
  followers           UserFollow[]     @relation("FollowFollowing")
  friendshipsStarted  UserFriendship[] @relation("FriendshipUserOne")
  friendshipsReceived UserFriendship[] @relation("FriendshipUserTwo")

  @@map("users")
}

model Book {
  id          String      @id @default(cuid())
  isbn        String      @unique
  title       String
  author      String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  inventory   Int         @default(0)
  category    String
  imageUrl    String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  cartItems   CartItem[]
  favorites   Favorite[]
  orderItems  OrderItem[]

  @@map("books")
}

model Order {
  id          String      @id @default(cuid())
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Decimal     @db.Decimal(10, 2)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orderNumber String      @unique
  items       OrderItem[]
  user        User        @relation(fields: [userId], references: [id])
  payment     Payment?

  @@map("orders")
}

model OrderItem {
  id       String  @id @default(cuid())
  orderId  String
  bookId   String
  quantity Int
  price    Decimal @db.Decimal(10, 2)
  book     Book    @relation(fields: [bookId], references: [id])
  order    Order   @relation(fields: [orderId], references: [id])

  @@map("order_items")
}

model CartItem {
  id       String @id @default(cuid())
  userId   String
  bookId   String
  quantity Int
  book     Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, bookId])
  @@map("cart_items")
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String        @unique
  stripePaymentId String        @unique
  amount          Decimal       @db.Decimal(10, 2)
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  order           Order         @relation(fields: [orderId], references: [id])

  @@map("payments")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  bookId    String
  createdAt DateTime @default(now())
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, bookId])
  @@map("favorites")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model BlogPost {
  id           String   @id @default(cuid())
  title        String
  content      String
  featureImage String?
  fontFamily   String   @default("modern-sans")
  visibility   BlogPostVisibility @default(PUBLIC)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([authorId])
  @@index([createdAt])
  @@index([visibility])

  @@map("blog_posts")
}

enum BlogPostVisibility {
  PUBLIC
  FOLLOWERS
  FRIENDS
  PRIVATE
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("user_follows")
}

model UserFriendship {
  id        String   @id @default(cuid())
  userOneId String
  userTwoId String
  createdAt DateTime @default(now())
  userOne   User     @relation("FriendshipUserOne", fields: [userOneId], references: [id], onDelete: Cascade)
  userTwo   User     @relation("FriendshipUserTwo", fields: [userTwoId], references: [id], onDelete: Cascade)

  @@unique([userOneId, userTwoId])
  @@index([userTwoId])
  @@map("user_friendships")
}

model Quote {
  id        String   @id @default(cuid())
  text      String
  author    String
  source    String?
  category  String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quotes")
}
